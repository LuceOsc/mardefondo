<script>
  // nav scroll background
  const nav = document.getElementById('mf-nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 40) {
        nav.style.background = 'rgba(245,241,234,0.92)';
        nav.style.boxShadow = '0 6px 24px rgba(42,48,71,0.08)';
        nav.style.backdropFilter = 'blur(10px)';
        nav.style.padding = '12px clamp(20px,5vw,60px)';
      } else {
        nav.style.background = 'rgba(245,241,234,0)';
        nav.style.boxShadow = 'none';
        nav.style.backdropFilter = 'blur(0)';
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // mobile hamburger drawer
  const burger = document.getElementById('mf-burger');
  const navmenu = document.getElementById('mf-navmenu');
  const overlay = document.getElementById('mf-overlay');
  const setOpen = (open: boolean) => {
    if (!navmenu) return;
    navmenu.classList.toggle('open', open);
    overlay?.classList.toggle('open', open);
    burger?.classList.toggle('open', open);
    burger?.setAttribute('aria-expanded', open ? 'true' : 'false');
    document.body.style.overflow = open ? 'hidden' : '';
  };
  burger?.addEventListener('click', () => setOpen(!navmenu?.classList.contains('open')));
  overlay?.addEventListener('click', () => setOpen(false));
  navmenu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });

  // scroll-reveal
  const revealEls = document.querySelectorAll<HTMLElement>('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('mf-in');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -7% 0px' }
    );
    revealEls.forEach((el) => io.observe(el));
  }
</script>
